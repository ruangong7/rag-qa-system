# LLM Configuration (Alibaba Cloud Model Studio / DashScope, OpenAI compatible)
LLM_PROVIDER=dashscope
DASHSCOPE_API_KEY=your-dashscope-api-key-here
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-max
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024
EMBEDDING_MODEL=BAAI/bge-m3
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
# ChromaDB (local, no Docker)
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION=rag_docs
BM25_INDEX_PATH=./chroma_data/bm25.pkl

# Retrieval
RETRIEVAL_DENSE_TOP_K=20
RETRIEVAL_SPARSE_TOP_K=20
RETRIEVAL_FUSION_TOP_K=10
RETRIEVAL_FINAL_TOP_K=3
RETRIEVAL_ENABLE_RERANK=false
RETRIEVAL_LOW_CONFIDENCE_THRESHOLD=0.35
WARMUP_DENSE_ON_STARTUP=true

# Conversation
MAX_HISTORY_ROUNDS=5
SESSION_TTL=3600
REDIS_URL=redis://localhost:6379/0

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=false
