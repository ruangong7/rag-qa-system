# LLM Configuration (Alibaba Cloud Model Studio / DashScope)
LLM_PROVIDER=dashscope
DASHSCOPE_API_KEY=
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-max
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024
EMBEDDING_MODEL=BAAI/bge-m3

# ChromaDB / sparse index
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION=rag_docs
BM25_INDEX_PATH=./chroma_data/bm25.pkl

# Retrieval
RETRIEVAL_DENSE_TOP_K=20
RETRIEVAL_SPARSE_TOP_K=20
RETRIEVAL_FUSION_TOP_K=6
RETRIEVAL_FINAL_TOP_K=3
RETRIEVAL_ENABLE_RERANK=true
RETRIEVAL_LOW_CONFIDENCE_THRESHOLD=0.35
WARMUP_DENSE_ON_STARTUP=true

# Conversation
MAX_HISTORY_ROUNDS=5
SESSION_TTL=3600
REDIS_URL=redis://localhost:6379/0

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=false
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# Reranker
RERANKER_MODEL=C:\Use***************************************************************
RERANKER_BATCH_SIZE=1
RERANKER_USE_FP16=false

RAGAS_LLM_API_KEY=sk-*****************************************************
RAGAS_LLM_BASE_URL=************************************************
RAGAS_LLM_MODEL=gpt-5.4
RAGAS_LLM_TEMPERATURE=0.0
RAGAS_LLM_TOP_P=1.0
RAGAS_LLM_MAX_TOKENS=4096
